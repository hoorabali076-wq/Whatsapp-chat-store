// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: chats
// Fields:
//   - contactName: string (required, 1-100 chars)
//   - lastMessage: string (0-500 chars)
//   - lastMessageTimestamp: timestamp (required)
//   - messageCount: number (required, >= 0)
//   - ownerId: string (required, matches auth.uid)
//   - tags: list of strings (max 10 tags, each < 30 chars)
//   - createdAt: timestamp (required)
//
// Collection: messages
// Fields:
//   - chatId: string (required, references chats)
//   - sender: string (1-100 chars)
//   - encryptedContent: string (required, 1-10000 chars)
//   - timestamp: timestamp (required)
//   - isMedia: boolean (required)
//   - ownerId: string (required, matches auth.uid)
//
// Collection: media
// Fields:
//   - chatId: string (required)
//   - messageId: string (optional)
//   - fileName: string (1-255 chars)
//   - fileType: string (1-50 chars)
//   - url: string (required, valid URL)
//   - ownerId: string (required, matches auth.uid)
//   - uploadedAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidChat(data) {
      return data.keys().hasAll(['contactName', 'ownerId', 'lastMessageTimestamp', 'createdAt']) &&
             isValidString(data.contactName, 1, 100) &&
             data.ownerId == request.auth.uid &&
             data.lastMessageTimestamp is timestamp &&
             data.createdAt is timestamp &&
             (!('lastMessage' in data) || data.lastMessage is string) &&
             (!('messageCount' in data) || data.messageCount is number) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'encryptedContent', 'timestamp', 'isMedia', 'ownerId']) &&
             data.chatId is string &&
             isValidString(data.encryptedContent, 1, 10000) &&
             data.timestamp is timestamp &&
             data.isMedia is bool &&
             data.ownerId == request.auth.uid;
    }

    function isValidMedia(data) {
      return data.keys().hasAll(['chatId', 'url', 'ownerId', 'uploadedAt']) &&
             data.chatId is string &&
             isValidUrl(data.url) &&
             data.ownerId == request.auth.uid &&
             data.uploadedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isDocOwner() && isValidChat(request.resource.data) && 
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner();
    }

    match /messages/{messageId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if isDocOwner() && isValidMessage(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.chatId == resource.data.chatId;
      allow delete: if isDocOwner();
    }

    match /media/{mediaId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidMedia(request.resource.data);
      allow update: if isDocOwner() && isValidMedia(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
